# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Examples:
#   Local: postgresql://postgres:postgres@localhost:5432/ai_news
#   Railway: postgresql://user:pass@containers-us-west-xxx.railway.app:5432/railway
#   Supabase: postgresql://postgres.xxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres
#   Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL=postgresql://user:password@localhost:5432/ai_news

# ============================================
# Authentication & Security
# ============================================
# JWT secret key - MUST be changed in production!
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# Stripe Billing Configuration
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Price ID for monthly subscription
# Create a product and price in Stripe Dashboard, then copy the Price ID
# Format: price_REPLACE_ME
SUBSCRIPTION_PRICE_ID=price_REPLACE_ME

# Stripe Webhook Setup:
# 1. Go to https://dashboard.stripe.com/webhooks
# 2. Add endpoint: https://your-domain.com/api/billing/webhook
# 3. Select events: checkout.session.completed, invoice.payment_succeeded, customer.subscription.deleted
# 4. Copy the webhook signing secret to STRIPE_WEBHOOK_SECRET above

# ============================================
# Usage Quotas (Prevent Billing Spikes)
# ============================================
# These limits help prevent unexpected hosting costs
# Adjust based on your needs and hosting plan

# Daily API request limit (default: 10,000)
DAILY_API_LIMIT=10000

# Monthly API request limit (default: 300,000)
MONTHLY_API_LIMIT=300000

# Daily news scraping limit (default: 1,000)
DAILY_SCRAPE_LIMIT=1000

# Monthly news scraping limit (default: 30,000)
MONTHLY_SCRAPE_LIMIT=30000

# ============================================
# News Scraping Configuration
# ============================================
# Timeout for scraping requests in milliseconds (default: 30 seconds)
SCRAPE_TIMEOUT=30000

# User agent for web scraping (default: AI-News-Bot/1.0)
USER_AGENT="Mozilla/5.0 (compatible; AI-News-Bot/1.0)"

ARTICLES_PER_SOURCE_KEYWORD=20

# ============================================
# CORS Configuration
# ============================================
# Allowed origins for CORS (comma-separated)
# For development, include localhost URLs
# For production, include your actual domain(s)
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:19006,https://your-domain.com"

# ============================================
# Optional: Development Only
# ============================================
# Uncomment for SQLite (development only, not recommended for production)
# DB_PATH=./data/database.sqlite
